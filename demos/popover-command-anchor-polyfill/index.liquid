---
title: "Popover, Anchor Positioning, Command Invoker with Polyfills"
tags: []
hide: false
---
<h1>{{ title }}</h1>


<button command="show-modal" commandfor="my-dialog">Open dialog</button>

<dialog id="my-dialog">
  <p>This dialog was opened using an invoker command.</p>
  <button commandfor="my-dialog" command="close">Close</button>
</dialog>

<hr/>
<div class="grid">
  {% for i in (1..12) %}
    <div style="anchor-name: --card-{{ i }}" class="card">
      <button popovertarget="info-{{ i }}">+</button>
      <div id="info-{{ i }}" style="position-anchor: --card-{{ i }}" popover>This is card #{{ i }}!</div>
    </div>
  {% endfor %}
</div>

<script type="module">
  if (!('anchorName' in document.documentElement.style)) {
    console.log('anchor polyfilled');
    import('/demos/popover-command-anchor-polyfill/css-anchor-positioning.js');
  }
  if (!('popover' in HTMLElement.prototype)) {
    console.log('popover polyfilled');
    import('/demos/popover-command-anchor-polyfill/popover-polyfill.js');
  }
  if (!('command' in HTMLButtonElement.prototype)) {
    console.log('invokers polyfiled');
    import('/demos/popover-command-anchor-polyfill/invoker.min.js');
  }
</script>
